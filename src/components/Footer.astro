---
const currentYear = new Date().getFullYear();
---

<footer class="py-12 border-t border-white/5 bg-slate-950/80 backdrop-blur-md relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 md:px-12 flex flex-col md:flex-row items-center justify-between gap-8 relative z-10">
    
    <!-- Branding / Logo & Tagline -->
    <div class="flex flex-col items-center md:items-start gap-3 text-center md:text-left">
      <div class="flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 320 68" class="h-9 w-auto">
          <defs>
            <linearGradient id="footer_mark" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" style="stop-color:rgba(255,255,255,0.12)"/>
              <stop offset="100%" style="stop-color:rgba(255,255,255,0.06)"/>
            </linearGradient>
          </defs>
          <rect x="2" y="2" width="56" height="56" rx="14" fill="url(#footer_mark)" stroke="rgba(255,255,255,0.15)" stroke-width="1.5"/>
          <line x1="12" y1="30" x2="20" y2="30" stroke="rgba(255,255,255,0.2)" stroke-width="1.5"/>
          <line x1="40" y1="30" x2="48" y2="30" stroke="rgba(255,255,255,0.2)" stroke-width="1.5"/>
          <line x1="30" y1="12" x2="30" y2="18" stroke="rgba(255,255,255,0.2)" stroke-width="1.5"/>
          <line x1="30" y1="42" x2="30" y2="48" stroke="rgba(255,255,255,0.2)" stroke-width="1.5"/>
          <circle cx="12" cy="30" r="2" fill="rgba(255,255,255,0.25)"/>
          <circle cx="48" cy="30" r="2" fill="rgba(255,255,255,0.25)"/>
          <circle cx="30" cy="12" r="2" fill="rgba(255,255,255,0.25)"/>
          <circle cx="30" cy="48" r="2" fill="rgba(255,255,255,0.25)"/>
          <circle cx="44" cy="16" r="3" fill="#e94560" opacity="0.9"/>
          <text x="30" y="40" text-anchor="middle" font-family="Segoe UI, system-ui, sans-serif" font-size="22" font-weight="900" fill="#ffffff" letter-spacing="-1">G</text>
          <rect x="22" y="43" width="16" height="2.5" rx="1.2" fill="#e94560"/>
          <text x="70" y="24" font-family="Segoe UI, system-ui, sans-serif" font-size="20" font-weight="900" fill="#ffffff" letter-spacing="-0.5"><tspan fill="#e94560">G-Soft</tspan> Business</text>
          <text x="70" y="41" font-family="Segoe UI, system-ui, sans-serif" font-size="14" font-weight="700" fill="rgba(255,255,255,0.6)" letter-spacing="-0.3">Solutions</text>
          <text x="70" y="56" font-family="Segoe UI, system-ui, sans-serif" font-size="11.5" font-weight="600" fill="rgba(255,255,255,0.4)" letter-spacing="1" text-transform="uppercase">Solutions with Purpose.</text>
        </svg>
      </div>
      <span class="text-[9px] font-bold text-slate-500 uppercase tracking-[0.25em] font-mono">Solutions with Purpose.</span>
    </div>

    <!-- Quick Navigation Links -->
    <nav class="flex flex-wrap items-center justify-center gap-6 md:gap-10">
      <a href="#services" class="text-xs font-semibold text-slate-400 hover:text-white transition-colors">Services</a>
      <a href="#projects" class="text-xs font-semibold text-slate-400 hover:text-white transition-colors">Projects</a>
      <a href="#process" class="text-xs font-semibold text-slate-400 hover:text-white transition-colors">Process</a>
    </nav>

    <!-- Copyright information -->
    <div class="text-center md:text-right space-y-1">
      <p class="text-xs text-slate-500 font-light">
        &copy; {currentYear} G-Soft Business Solutions. All rights reserved.
      </p>
      <p class="text-[9px] text-slate-600 font-mono">
        Designed & Programmed with Purpose.
      </p>
    </div>
    
  </div>
</footer>
