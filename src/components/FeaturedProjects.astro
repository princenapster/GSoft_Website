---
const projects = [
  {
    title: "G-Power Solartech OPC",
    category: "Clean Energy Portal",
    description: "A premium corporate portal and interactive savings calculator built for a leading solar panel supply and installation provider in the Philippines. Features custom savings estimators and ROI calculators.",
    tags: ["HTML5", "CSS3", "JavaScript", "FontAwesome"],
    stats: { label: "Average Bill Cut", value: "75%" },
    mockupType: "solar",
    githubUrl: "https://github.com/princenapster/g-power-solartech"
  },
  {
    title: "Kerusso Production System",
    category: "Garment ERP System",
    description: "A real-time workflow tracking system built for a garment printing and embroidery enterprise. Features active production boards, live factory floor display syncing, and automated material audits.",
    tags: ["NodeJS", "Express", "EJS", "PostgreSQL"],
    stats: { label: "Status Auto-Sync", value: "100%" },
    mockupType: "production",
    githubUrl: "https://github.com/princenapster/snp-app"
  },
  {
    title: "Stitch & Print Payroll Wizard",
    category: "HR & Payroll Automation",
    description: "An automated HR platform with CSV time record (DTR) log importing, salary matrix settings, overtime/leave tracking, and a multi-step wizard generating secure employee payslips.",
    tags: ["NodeJS", "Express", "EJS", "PostgreSQL", "Multer"],
    stats: { label: "Import Load Time", value: "<0.5s" },
    mockupType: "payroll",
    githubUrl: "https://github.com/princenapster/snp-payroll"
  }
];
---

<section id="projects" class="py-24 relative overflow-hidden bg-slate-950/40">
  <div class="max-w-7xl mx-auto px-6 md:px-12 relative z-10">
    
    <!-- Section Header -->
    <div class="max-w-2xl mb-16">
      <div class="flex items-center gap-2 text-[#e94560] font-semibold text-xs uppercase tracking-[0.2em] mb-3">
        <span class="w-1.5 h-1.5 rounded-full bg-[#e94560]"></span>
        Our Projects
      </div>
      <h2 class="text-3xl sm:text-4xl font-extrabold text-white tracking-tight">
        Featured Systems & Products
      </h2>
      <p class="text-slate-400 font-light mt-4 leading-relaxed">
        Discover G-Soft's custom engineering. Below are active business applications, automated workflows, and corporate platforms built to optimize operations.
      </p>
    </div>

    <!-- Projects Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      {projects.map((project) => (
        <div class="glassmorphic-card rounded-2xl overflow-hidden border border-white/5 flex flex-col justify-between group">
          <!-- Mockup Visual Frame (Top Half of Card) -->
          <div class="h-48 bg-slate-950/80 border-b border-white/5 p-4 flex items-center justify-center relative overflow-hidden">
            <!-- Grid overlay -->
            <div class="absolute inset-0 bg-grid-pattern opacity-30 pointer-events-none"></div>
            <div class="absolute inset-0 bg-blue-900/5 group-hover:bg-[#e94560]/5 transition-all duration-500 pointer-events-none"></div>

            <!-- Custom Mockups based on Type -->
            {project.mockupType === 'solar' && (
              <div class="w-full h-full flex flex-col justify-between font-mono text-[10px] text-slate-500">
                <div class="flex items-center justify-between border-b border-white/5 pb-2">
                  <span class="text-yellow-500 flex items-center gap-1">☀ G-Power Solar monitor</span>
                  <span class="text-emerald-400">Yield: 24.2 kWh</span>
                </div>
                <!-- Savings Graph -->
                <div class="flex items-end justify-between h-20 pt-2 pb-1 relative">
                  <!-- Chart baseline grid -->
                  <div class="absolute inset-x-0 bottom-1 h-[1px] bg-slate-800"></div>
                  
                  <div class="flex flex-col items-center w-[15%]">
                    <div class="bg-yellow-600/30 group-hover:bg-yellow-500/40 w-full rounded-t h-8 transition-all duration-300"></div>
                    <span class="text-[7px] mt-1">Jan</span>
                  </div>
                  <div class="flex flex-col items-center w-[15%]">
                    <div class="bg-yellow-600/40 group-hover:bg-yellow-500/50 w-full rounded-t h-12 transition-all duration-300"></div>
                    <span class="text-[7px] mt-1">Feb</span>
                  </div>
                  <div class="flex flex-col items-center w-[15%]">
                    <div class="bg-yellow-600/50 group-hover:bg-yellow-500/60 w-full rounded-t h-16 transition-all duration-300"></div>
                    <span class="text-[7px] mt-1">Mar</span>
                  </div>
                  <div class="flex flex-col items-center w-[15%]">
                    <div class="bg-yellow-500/70 group-hover:bg-yellow-500/80 w-full rounded-t h-[72px] transition-all duration-300"></div>
                    <span class="text-[7px] mt-1">Apr</span>
                  </div>
                  <div class="flex flex-col items-center w-[15%]">
                    <div class="bg-yellow-500/80 group-hover:bg-[#e94560]/80 w-full rounded-t h-[60px] transition-all duration-300"></div>
                    <span class="text-[7px] mt-1">May</span>
                  </div>
                </div>
              </div>
            )}

            {project.mockupType === 'production' && (
              <div class="w-full h-full flex flex-col justify-between font-mono text-[9px] text-slate-500">
                <div class="flex items-center justify-between border-b border-white/5 pb-1.5">
                  <span class="text-indigo-400 font-semibold flex items-center gap-1">■ Production Board</span>
                  <span class="text-slate-400 text-[8px] animate-pulse">Floor Sync: Active</span>
                </div>
                
                <!-- Mock Kanban Lanes -->
                <div class="grid grid-cols-3 gap-2 flex-1 pt-2">
                  <div class="bg-slate-900/60 p-1.5 rounded border border-white/5 flex flex-col gap-1.5">
                    <span class="text-[7px] text-slate-400 uppercase tracking-wider">Printing</span>
                    <div class="bg-slate-950 p-1 rounded border-l-2 border-indigo-500 text-[7px] text-slate-300 truncate">
                      JO-2026-004
                    </div>
                  </div>
                  
                  <div class="bg-slate-900/60 p-1.5 rounded border border-white/5 flex flex-col gap-1.5">
                    <span class="text-[7px] text-slate-400 uppercase tracking-wider">Sewing</span>
                    <div class="bg-slate-950 p-1 rounded border-l-2 border-[#e94560] text-[7px] text-slate-300 truncate">
                      JO-2026-002
                    </div>
                  </div>

                  <div class="bg-slate-900/60 p-1.5 rounded border border-white/5 flex flex-col gap-1.5">
                    <span class="text-[7px] text-slate-400 uppercase tracking-wider">QC & Pack</span>
                    <div class="bg-slate-950 p-1 rounded border-l-2 border-emerald-500 text-[7px] text-slate-300 truncate">
                      JO-2026-001
                    </div>
                  </div>
                </div>
              </div>
            )}

            {project.mockupType === 'payroll' && (
              <div class="w-full h-full flex flex-col justify-between font-mono text-[9px] text-slate-500">
                <div class="bg-slate-900/60 p-2 border border-white/5 rounded flex items-center justify-between mb-1.5">
                  <span class="text-slate-300 font-semibold flex items-center gap-1.5">
                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                    Payroll Wizard - Step 3
                  </span>
                  <span class="text-slate-500 text-[8px]">DTR Upload Complete</span>
                </div>
                
                <div class="flex-1 border border-white/5 rounded bg-slate-900/40 p-2 space-y-1.5 overflow-hidden">
                  <div class="flex justify-between text-slate-400 text-[8px]">
                    <span>Process Period: June 1-15</span>
                    <span class="text-emerald-400">Status: Calculated</span>
                  </div>
                  <div class="grid grid-cols-2 gap-2 text-[8px] border-t border-white/5 pt-1.5 text-slate-400">
                    <div>Gross Income: <span class="text-slate-200">$4,850.00</span></div>
                    <div>Deductions: <span class="text-[#e94560]">$230.00</span></div>
                    <div class="col-span-2 font-bold text-white text-[9px] border-t border-white/5 pt-1">
                      Net Pay: <span class="text-emerald-400">$4,620.00</span>
                    </div>
                  </div>
                </div>
              </div>
            )}
          </div>

          <!-- Project Details (Bottom Half of Card) -->
          <div class="p-6 md:p-8 flex-1 flex flex-col justify-between">
            <div>
              <div class="flex items-center justify-between mb-3">
                <span class="text-xs font-semibold text-[#e94560] tracking-wider uppercase">{project.category}</span>
                <!-- Stats badge -->
                <div class="text-right">
                  <div class="text-sm font-bold text-white group-hover:text-[#e94560] transition-colors">{project.stats.value}</div>
                  <div class="text-[9px] text-slate-500 tracking-wide uppercase">{project.stats.label}</div>
                </div>
              </div>
              
              <h3 class="text-xl font-bold text-white mb-2 group-hover:text-slate-300 transition-colors">{project.title}</h3>
              <p class="text-slate-400 text-xs sm:text-sm font-light leading-relaxed mb-6">{project.description}</p>
            </div>

            <!-- Tags -->
            <div class="flex flex-wrap gap-1.5 pt-4 border-t border-white/5">
              {project.tags.map((tag) => (
                <span class="text-[9px] font-mono text-slate-400 px-2 py-0.5 rounded bg-slate-900/80 border border-white/5">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
