---
const services = [
  {
    title: "Custom Software Development",
    description: "Designing and engineering tailored enterprise platforms, cloud applications, and high-performance business software built for speed, security, and scalability.",
    iconPath: "M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z",
    tech: ["Web Apps", "Desktop Apps", "APIs", "Database Systems"]
  },
  {
    title: "Mobile & Cloud Engineering",
    description: "Building cross-platform and native mobile apps integrated with resilient, auto-scaling cloud architectures on AWS, Azure, and Google Cloud Platform.",
    iconPath: "M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z",
    tech: ["iOS & Android", "Cloud Native", "Serverless", "DevOps"]
  },
  {
    title: "Architecture & Optimization",
    description: "Refactoring legacy codebases, optimizing query execution plans, and upgrading existing architectures to handle heavy traffic and complex business flows.",
    iconPath: "M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4",
    tech: ["Legacy Upgrades", "Database Tuning", "Performance Audits", "Microservices"]
  },
  {
    title: "AI & Business Automation",
    description: "Automating manual business pipelines and data entry workflows using custom AI modules, intelligent OCR, data parsers, and custom integrations.",
    iconPath: "M13 10V3L4 14h7v7l9-11h-7z",
    tech: ["ML Integrations", "Intelligent Pipelines", "OCR & Parsers", "Workflows"]
  }
];
---

<section id="services" class="py-24 relative overflow-hidden">
  <!-- Glowing decorative elements -->
  <div class="absolute top-1/2 left-0 w-72 h-72 rounded-full bg-blue-900/10 blur-[100px] pointer-events-none -z-10"></div>
  <div class="absolute bottom-0 right-10 w-96 h-96 rounded-full bg-[#e94560]/5 blur-[120px] pointer-events-none -z-10"></div>

  <div class="max-w-7xl mx-auto px-6 md:px-12 relative z-10">
    
    <!-- Section Header -->
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6">
      <div class="max-w-xl">
        <div class="flex items-center gap-2 text-[#e94560] font-semibold text-xs uppercase tracking-[0.2em] mb-3">
          <span class="w-1.5 h-1.5 rounded-full bg-[#e94560]"></span>
          Expertise & Capabilities
        </div>
        <h2 class="text-3xl sm:text-4xl font-extrabold text-white tracking-tight">
          Solutions Engineered <br class="hidden sm:inline" />
          for Complex Challenges
        </h2>
      </div>
      <p class="text-slate-400 max-w-sm text-sm leading-relaxed font-light">
        We bridge the gap between technical complexity and business growth, creating custom solutions that act as strategic leverage for your operations.
      </p>
    </div>

    <!-- Services Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
      {services.map((service) => (
        <div class="glassmorphic-card p-8 rounded-2xl relative group overflow-hidden flex flex-col justify-between">
          <!-- Circuit corner glow effect -->
          <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-br from-white/5 via-transparent to-transparent pointer-events-none"></div>
          
          <!-- Circuit dot (logo themed red node in upper right of active cards) -->
          <div class="absolute top-5 right-5 w-2.5 h-2.5 rounded-full bg-white/10 group-hover:bg-[#e94560] group-hover:shadow-[0_0_8px_#e94560] transition-all duration-300"></div>

          <div>
            <!-- Icon Container -->
            <div class="w-12 h-12 rounded-xl flex items-center justify-center bg-blue-950/60 border border-blue-900/30 text-blue-400 mb-6 group-hover:border-[#e94560]/30 group-hover:text-[#e94560] transition-colors duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={service.iconPath} />
              </svg>
            </div>

            <!-- Content -->
            <h3 class="text-xl font-bold text-white mb-3 group-hover:text-[#e94560] transition-colors duration-300">
              {service.title}
            </h3>
            
            <p class="text-slate-400 text-sm leading-relaxed font-light mb-6">
              {service.description}
            </p>
          </div>

          <!-- Tech Tags -->
          <div class="flex flex-wrap gap-2 pt-4 border-t border-white/5">
            {service.tech.map((t) => (
              <span class="text-[10px] font-mono font-semibold tracking-wide text-slate-400 px-2.5 py-1 rounded bg-slate-900/60 border border-white/5">
                {t}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
