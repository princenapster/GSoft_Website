---
---
<section id="contact" class="py-24 relative overflow-hidden">
  <!-- Glow backdrop -->
  <div class="absolute bottom-0 left-[20%] w-[35vw] h-[35vw] rounded-full bg-[#1e3a8a]/10 blur-[130px] pointer-events-none -z-10"></div>

  <div class="max-w-7xl mx-auto px-6 md:px-12 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">
      
      <!-- Contact Info & Profiles (6 Columns) -->
      <div class="lg:col-span-6 space-y-12">
        <div>
          <div class="flex items-center gap-2 text-[#e94560] font-semibold text-xs uppercase tracking-[0.2em] mb-3">
            <span class="w-1.5 h-1.5 rounded-full bg-[#e94560]"></span>
            Get in Touch
          </div>
          <h2 class="text-3xl sm:text-4xl font-extrabold text-white tracking-tight">
            Connect with Our Team
          </h2>
          <p class="text-slate-400 font-light mt-4 leading-relaxed max-w-md">
          Have a project in mind or want to modernize your existing infrastructure? Contact our team or fill out the request form.
          </p>
        </div>

        <!-- Corporate Contact Details -->
        <div class="space-y-8">
          <div class="space-y-4">
            <h3 class="text-lg font-bold text-white tracking-tight">Channels</h3>
            
            <div class="flex flex-col gap-4">
              <!-- Email Capsule -->
              <a href="mailto:gsoftbusinesssolutions@gmail.com" class="px-5 py-3.5 rounded-2xl bg-slate-900/40 hover:bg-slate-900/60 border border-white/5 hover:border-[#e94560]/30 flex items-center gap-4 text-xs text-slate-300 hover:text-white transition-all duration-300 shadow-lg group">
                <div class="w-8 h-8 rounded-lg bg-blue-950/60 border border-blue-900/30 text-blue-400 group-hover:border-[#e94560]/30 group-hover:text-[#e94560] flex items-center justify-center transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div class="text-left">
                  <div class="text-[10px] text-slate-500 uppercase font-bold tracking-wider">Corporate Email</div>
                  <div class="font-mono mt-0.5">gsoftbusinesssolutions@gmail.com</div>
                </div>
              </a>

              <!-- Facebook Capsule -->
              <a href="https://facebook.com/gsoftbusinesssolutionsph" target="_blank" rel="noopener noreferrer" class="px-5 py-3.5 rounded-2xl bg-slate-900/40 hover:bg-slate-900/60 border border-white/5 hover:border-[#e94560]/30 flex items-center gap-4 text-xs text-slate-300 hover:text-white transition-all duration-300 shadow-lg group">
                <div class="w-8 h-8 rounded-lg bg-blue-950/60 border border-blue-900/30 text-blue-400 group-hover:border-[#e94560]/30 group-hover:text-[#e94560] flex items-center justify-center transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 fill="currentColor" viewBox="0 0 24 24">
                    <path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/>
                  </svg>
                </div>
                <div class="text-left">
                  <div class="text-[10px] text-slate-500 uppercase font-bold tracking-wider">Facebook Page</div>
                  <div class="font-mono mt-0.5">gsoftbusinesssolutionsph</div>
                </div>
              </a>

              <!-- Phone Capsule -->
              <a href="tel:09209672028" class="px-5 py-3.5 rounded-2xl bg-slate-900/40 hover:bg-slate-900/60 border border-white/5 hover:border-[#e94560]/30 flex items-center gap-4 text-xs text-slate-300 hover:text-white transition-all duration-300 shadow-lg group">
                <div class="w-8 h-8 rounded-lg bg-blue-950/60 border border-blue-900/30 text-blue-400 group-hover:border-[#e94560]/30 group-hover:text-[#e94560] flex items-center justify-center transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div class="text-left">
                  <div class="text-[10px] text-slate-500 uppercase font-bold tracking-wider">Hotline</div>
                  <div class="font-mono mt-0.5">0920 9672028</div>
                </div>
              </a>

              <!-- Location Capsule -->
              <div class="px-5 py-3.5 rounded-2xl bg-slate-900/40 border border-white/5 flex items-center gap-4 text-xs text-slate-300 shadow-lg">
                <div class="w-8 h-8 rounded-lg bg-blue-950/60 border border-blue-900/30 text-blue-400 flex items-center justify-center">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <div class="text-left">
                  <div class="text-[10px] text-slate-500 uppercase font-bold tracking-wider">HQ Location</div>
                  <div class="mt-0.5">Imus City, Cavite Ph</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Request Form (6 Columns) -->
      <div class="lg:col-span-6 glassmorphic p-8 rounded-2xl border-white/5 shadow-2xl relative">
        <!-- Glowing corner indicators -->
        <div class="absolute -top-1 -right-1 w-2.5 h-2.5 rounded-full bg-[#e94560] animate-pulse-glow"></div>
        <div class="absolute -bottom-1 -left-1 w-2.5 h-2.5 rounded-full bg-blue-500/80 shadow-[0_0_8px_rgba(59,130,246,0.5)]"></div>

        <form id="contact-form" class="space-y-6">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div class="space-y-2">
              <label for="contact-name" class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider">Full Name</label>
              <input type="text" id="contact-name" required class="w-full px-4 py-3 rounded-xl bg-slate-950/60 border border-white/5 focus:border-[#e94560]/60 focus:ring-0 text-slate-200 text-sm transition-all focus:outline-none" placeholder="John Doe" />
            </div>
            <div class="space-y-2">
              <label for="contact-email" class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider">Email Address</label>
              <input type="email" id="contact-email" required class="w-full px-4 py-3 rounded-xl bg-slate-950/60 border border-white/5 focus:border-[#e94560]/60 focus:ring-0 text-slate-200 text-sm transition-all focus:outline-none" placeholder="johndoe@example.com" />
            </div>
          </div>

          <div class="space-y-2">
            <label for="contact-subject" class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider">Inquiry Subject</label>
            <select id="contact-subject" class="w-full px-4 py-3 rounded-xl bg-slate-950/60 border border-white/5 focus:border-[#e94560]/60 focus:ring-0 text-slate-200 text-sm transition-all focus:outline-none" required>
              <option value="project-consultation" selected>Project Consultation</option>
              <option value="system-modernization">System Modernization</option>
              <option value="general-inquiry">General Inquiry</option>
            </select>
          </div>

          <div class="space-y-2">
            <label for="contact-message" class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider">Project Specification / message</label>
            <textarea id="contact-message" rows="5" required class="w-full px-4 py-3 rounded-xl bg-slate-950/60 border border-white/5 focus:border-[#e94560]/60 focus:ring-0 text-slate-200 text-sm transition-all focus:outline-none font-mono text-xs resize-none" placeholder="Describe your technical requirements or system specifications..."></textarea>
          </div>

          <button type="submit" id="submit-form-btn" class="w-full py-4 rounded-xl font-bold bg-gradient-to-r from-blue-700 to-indigo-800 border border-blue-500/20 text-white hover:border-[#e94560]/30 hover:shadow-[0_0_15px_rgba(233,69,96,0.1)] transition-all duration-300 flex items-center justify-center gap-2">
            Submit Specifications
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
          </button>
        </form>

        <!-- Submit success/error display -->
        <div id="form-status" class="hidden mt-4 p-4 rounded-xl text-center text-xs font-semibold"></div>
      </div>

    </div>
  </div>
</section>

<script>
  // Simple contact form submission handling
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const statusDisplay = document.getElementById('form-status');
  const submitBtn = document.getElementById('submit-form-btn') as HTMLButtonElement;

  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      // Simulate sending animation
      submitBtn.disabled = true;
      submitBtn.innerHTML = `Sending Specifications... <span class="animate-spin inline-block w-4 h-4 border-2 border-white border-t-transparent rounded-full ml-1"></span>`;
      
      setTimeout(() => {
        submitBtn.disabled = false;
        submitBtn.innerHTML = `Submit Specifications <svg xmlns="http://www.w3.org/2000/svg" class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>`;
        
        statusDisplay.classList.remove('hidden', 'bg-red-500/10', 'text-red-400', 'border-red-500/20');
        statusDisplay.classList.add('bg-emerald-500/10', 'text-emerald-400', 'border', 'border-emerald-500/20');
        statusDisplay.textContent = "✔ Specifications transmitted successfully! Our Solutions Developers will reach out within 24 hours.";
        
        form.reset();
      }, 1500);
    });
  }
</script>
