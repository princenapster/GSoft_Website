---
---
<section class="relative min-h-screen pt-36 pb-24 flex items-center justify-start overflow-hidden bg-gradient-to-b from-[#1b2e5c]/10 via-transparent to-[#101c38]/20">
  <!-- Immersive Interactive Background Grids -->
  <div class="absolute inset-0 bg-grid-pattern opacity-40"></div>
  
  <!-- Glowing central radial light -->
  <div class="absolute top-1/4 left-1/4 w-[60vw] h-[60vw] rounded-full bg-[#3154bc]/10 blur-[130px] pointer-events-none -z-10"></div>
  <div class="absolute bottom-1/4 right-1/4 w-[40vw] h-[40vw] rounded-full bg-[#e94560]/5 blur-[120px] pointer-events-none -z-10"></div>

  <!-- Decorative Circuit Traces (flowing lines across screen) -->
  <div class="absolute top-[22%] left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-[#3154bc]/30 to-transparent circuit-line"></div>
  <div class="absolute bottom-[35%] left-0 w-full h-[1px] bg-gradient-to-r from-transparent via-[#e94560]/25 to-transparent circuit-line"></div>

  <!-- Floating Glowing Micro-Nodes -->
  <div class="absolute top-[32%] left-[18%] w-2 h-2 rounded-full bg-[#e94560] animate-pulse shadow-[0_0_10px_#e94560]"></div>
  <div class="absolute bottom-[28%] left-[8%] w-2.5 h-2.5 rounded-full bg-[#3154bc] animate-ping opacity-60"></div>
  <div class="absolute top-[45%] left-[40%] w-1.5 h-1.5 rounded-full bg-slate-400 opacity-40"></div>

  <div class="max-w-7xl mx-auto px-6 md:px-12 w-full flex items-center justify-between relative z-10">
    
    <!-- Text Content Column -->
    <div class="flex flex-col items-start text-left max-w-3xl">
      <!-- Tagline Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-slate-900/60 border border-[#e94560]/20 hover:border-[#e94560]/40 transition-colors duration-300 text-xs font-semibold text-slate-300 mb-8 uppercase tracking-[0.2em] shadow-inner shadow-slate-950">
        <span class="w-1.5 h-1.5 rounded-full bg-[#e94560] animate-pulse-glow"></span>
        Solutions with Purpose
      </div>
      
      <!-- Premium Headline -->
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-black text-white tracking-tight leading-[1.05] mb-6 select-none">
        Architecting <br class="hidden sm:inline" />
        <span class="bg-gradient-to-r from-white via-slate-100 to-slate-400 text-transparent bg-clip-text">Digital Systems</span><br />
        <span class="font-light text-slate-300">With Absolute</span> 
        <span class="text-[#e94560] text-glow-red relative inline-block font-black">
          Purpose
          <span class="absolute bottom-[-6px] left-0 w-full h-[3px] bg-gradient-to-r from-[#e94560] to-[#3154bc] rounded-full shadow-[0_2px_12px_#e94560]"></span>
        </span>
      </h1>
      
      <!-- Subtitle -->
      <p class="text-base sm:text-lg text-slate-300/80 max-w-xl mb-10 leading-relaxed font-light">
        G-Soft Business Solutions engineers high-performance enterprise applications, automated system integrations, and modern cloud platforms tailored to drive business velocity.
      </p>
      
      <!-- Action Buttons with Premium Hover Glows -->
      <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
        <a href="#projects" class="group relative px-8 py-4 rounded-xl text-center font-bold text-white bg-gradient-to-r from-blue-700 to-indigo-800 border border-blue-500/20 shadow-lg shadow-indigo-950/40 overflow-hidden transition-all duration-300 hover:border-[#e94560]/40 hover:shadow-[0_0_25px_rgba(233,69,96,0.2)] hover:-translate-y-0.5 active:translate-y-0 flex items-center justify-center gap-2">
          <!-- Light slide sheen on hover -->
          <span class="absolute inset-0 bg-gradient-to-r from-white/0 via-white/10 to-white/0 -translate-x-full group-hover:translate-x-full transition-transform duration-1000 ease-out"></span>
          Explore Projects
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
        <a href="#contact" class="px-8 py-4 rounded-xl text-center font-semibold text-slate-300 hover:text-white glassmorphic border-slate-800 hover:border-slate-600 transition-all hover:bg-slate-900/40 hover:-translate-y-0.5 active:translate-y-0">
          Partner with Us
        </a>
      </div>

      <!-- Quick Trust Indicators / Micro stats -->
      <div class="flex items-center gap-6 mt-16 pt-8 border-t border-white/5 w-full text-slate-500 font-mono text-[10px] uppercase tracking-wider">
        <div class="flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
          Enterprise Grade
        </div>
        <div class="flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-[#e94560]"></span>
          High Velocity
        </div>
        <div class="flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-blue-500"></span>
          Cloud Native
        </div>
      </div>
    </div>

    <!-- Absolutely positioned SVG Circuit Engine on the right (Desktop only) -->
    <div class="hidden lg:block w-[420px] h-[420px] relative pointer-events-none select-none flex-shrink-0">
      <!-- Glow bubble behind the engine -->
      <div class="absolute inset-10 rounded-full bg-gradient-to-br from-[#3154bc]/10 to-[#e94560]/10 blur-3xl opacity-80 animate-pulse"></div>
      
      <!-- The Tech Circuit Board SVG -->
      <svg viewBox="0 0 200 200" class="w-full h-full drop-shadow-[0_0_20px_rgba(49,84,188,0.15)]">
        <!-- Central Processor Chip -->
        <rect x="75" y="75" width="50" height="50" rx="10" fill="#0f1b38" stroke="#3154bc" stroke-width="2" />
        <rect x="80" y="80" width="40" height="40" rx="6" fill="#1b2e5c" stroke="#e94560" stroke-width="1.5" />
        
        <!-- Central core pulsing light -->
        <circle cx="100" cy="100" r="10" fill="#e94560" class="animate-pulse shadow-2xl" />
        <circle cx="100" cy="100" r="16" fill="none" stroke="#e94560" stroke-width="1" class="animate-ping opacity-25 origin-center" />

        <!-- Circuit Traces & Nodes -->
        <!-- Top Left -->
        <path d="M 75,90 L 45,90 L 35,70 L 15,70" fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="1.5" />
        <circle cx="15" cy="70" r="3" fill="#0f1b38" stroke="#3154bc" stroke-width="1.5" />
        <!-- Pulse packet on trace -->
        <circle cx="45" cy="90" r="2" fill="#e94560">
          <animateMotion path="M 75,90 L 45,90 L 35,70 L 15,70" dur="4s" repeatCount="indefinite" />
        </circle>

        <!-- Top Right -->
        <path d="M 100,75 L 100,45 L 120,35 L 140,35" fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="1.5" />
        <circle cx="140" cy="35" r="3" fill="#0f1b38" stroke="#e94560" stroke-width="1.5" />
        <circle cx="100" cy="45" r="2" fill="#3154bc">
          <animateMotion path="M 100,75 L 100,45 L 120,35 L 140,35" dur="3s" repeatCount="indefinite" />
        </circle>

        <!-- Bottom Right -->
        <path d="M 125,110 L 155,110 L 165,130 L 185,130" fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="1.5" />
        <circle cx="185" cy="130" r="3" fill="#0f1b38" stroke="#3154bc" stroke-width="1.5" />
        <circle cx="155" cy="110" r="2" fill="#e94560">
          <animateMotion path="M 125,110 L 155,110 L 165,130 L 185,130" dur="5s" repeatCount="indefinite" />
        </circle>

        <!-- Bottom Left -->
        <path d="M 100,125 L 100,155 L 80,165 L 60,165" fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="1.5" />
        <circle cx="60" cy="165" r="3" fill="#0f1b38" stroke="#e94560" stroke-width="1.5" />
        <circle cx="100" cy="155" r="2" fill="#3154bc">
          <animateMotion path="M 100,125 L 100,155 L 80,165 L 60,165" dur="3.5s" repeatCount="indefinite" />
        </circle>

        <!-- Tech grid ticks in margins -->
        <line x1="20" y1="20" x2="30" y2="20" stroke="rgba(255,255,255,0.1)" stroke-width="1" />
        <line x1="20" y1="20" x2="20" y2="30" stroke="rgba(255,255,255,0.1)" stroke-width="1" />
        <line x1="180" y1="180" x2="170" y2="180" stroke="rgba(255,255,255,0.1)" stroke-width="1" />
        <line x1="180" y1="180" x2="180" y2="170" stroke="rgba(255,255,255,0.1)" stroke-width="1" />
      </svg>
    </div>
  </div>
</section>
